# Copy to .env: cp .env.example .env
#
# Development: docker-compose overrides DATABASE_URL to db service.
# Production (Railway): set DATABASE_URL=${{Postgres.DATABASE_URL}}

APP_ENV=development
APP_SECRET=change-me-to-a-random-secret-key

DATABASE_URL=postgresql://vayno:vayno@localhost:5432/vayno?serverVersion=16&charset=utf8

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RESERVATION_GRACE_MINUTES=15

# Comma-separated frontend origins (CRM). No wildcards.
CORS_ORIGINS=http://localhost:3000

MESSENGER_TRANSPORT_DSN=sync://
